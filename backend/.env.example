# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
# Development
FRONTEND_URL=http://localhost:3000
# Production (set to your Vercel URL)
# FRONTEND_URL=https://your-app.vercel.app

# JWT — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# LLM / OpenAI (optional — falls back to rule-based scoring if not set)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Email — Option 1: SMTP (Gmail, Outlook, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Rent Finder <your@gmail.com>"

# Email — Option 2: SendGrid
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# If neither email option is set, Ethereal preview URLs are logged to console

# Compatibility scoring threshold for high-match alert email
HIGH_SCORE_THRESHOLD=80
